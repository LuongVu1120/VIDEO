# ===================== DATABASE =====================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/archvideo
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/archvideo
# Set FORCE_POSTGRES=true in production to prevent SQLite fallback
FORCE_POSTGRES=true
REDIS_URL=redis://redis:6379/0

# ===================== STORAGE =====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=arch-video-outputs
AWS_REGION=ap-southeast-1

# ===================== AI - VISION & TEXT =====================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===================== AI - DEEPSEEK V4 =====================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===================== AI - IMAGE GENERATION =====================
REPLICATE_API_TOKEN=

# ===================== AI - VIDEO GENERATION =====================
VIDEO_PROVIDER=fal
FAL_KEY=
# Video cost (fal, audio off): 2.5 Turbo ~$0.21/5s | O3 Standard ~$0.42/5s
FAL_VIDEO_MODEL=fal-ai/kling-video/v2.5-turbo/standard/image-to-video
# FAL_VIDEO_MODEL=fal-ai/kling-video/o3/standard/image-to-video
FAL_VIDEO_DURATION=5
FAL_VIDEO_GENERATE_AUDIO=false
FAL_VIDEO_TIMEOUT_SECONDS=600
# Max variations that receive a video (1 saves ~50% vs generating 2 videos)
VIDEO_MAX_VARIATIONS=1
# Ghép nhạc nền FFmpeg (thư mục backend/bgm/) — không tốn thêm fal
VIDEO_ADD_BGM=true
BGM_VOLUME=0.22
# BGM_LIBRARY_DIR=
GOOGLE_API_KEY=
RUNWAY_API_KEY=

# ===================== SOCIAL MEDIA =====================
BUFFER_ACCESS_TOKEN=

# Instagram (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=         # Lấy tại: graph.facebook.com/me?fields=id&access_token=TOKEN

# TikTok
TIKTOK_ACCESS_TOKEN=

# Facebook Page (Graph API)
FACEBOOK_PAGE_ID=          # ID trang Facebook của bạn
FACEBOOK_PAGE_ACCESS_TOKEN= # Page Access Token (không phải User token)

# YouTube Data API
YOUTUBE_CLIENT_SECRETS_FILE=youtube_client_secret.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=22

# URL backend công khai (Instagram cần tải được ảnh/video). Dev local: http://127.0.0.1:8000 ; production/ngrok: https://your-domain
PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000

# ===================== APP =====================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
AI_PROVIDER=claude
USE_DEEPSEEK_FOR_PROMPTS=true
USE_DEEPSEEK_FOR_CAPTIONS=true
# Agent / nội dung tiếng Việt
CONTENT_LANGUAGE=vi
CAPTION_POST_LANGUAGE=vi
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# ===================== BRANDING / WATERMARK =====================
# Để trống nếu không muốn thêm watermark
BRAND_NAME=Công Ty Kiến Trúc ABC
BRAND_PHONE=0901 234 567
# Vị trí: bottom-right | bottom-left | top-right | top-left
BRAND_WATERMARK_POSITION=bottom-right
